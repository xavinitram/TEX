# TEX cache (auto-generated at runtime). The glob catches any variant a stray
# TEX_CACHE_DIR or a direct `pytest` run (which skips run_all.py's scratch default)
# might drop — e.g. tests/.tex_cache_test/ — so cook artifacts never reach a commit.
.tex_cache/
.tex_cache*/
**/.tex_cache*/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Build/dist artifacts
*.egg-info/
dist/
build/

# Testing
.pytest_cache/

# Editor build (node_modules only — source and bundle are tracked)
editor_build/node_modules/

# Benchmark results (machine-specific; not committed)
benchmarks/results/
results/

# Internal reports (not shipped)
optimization_reports/
error_reports/

# Intermediate benchmark JSON files from development
tests/*.json
# ...but the LANG-3 compat-corpus goldens are a COMMITTED release artifact (the PM-4 gate).
!tests/compat_corpus_goldens.json

wiki/
.coverage
