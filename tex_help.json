            "spatial",
            "non-local"
          ],
          "aliases": []
        },
        {
          "name": "sample_cubic",
          "sig": "sample_cubic(img, u, v) → vec",
          "desc": "Bicubic (Catmull-Rom) sampling.",
          "example": "@OUT = sample_cubic(@A, u, v);",
          "tags": [
            "spatial",
            "non-local"
          ],
          "aliases": []
        },
        {
          "name": "sample_lanczos",
          "sig": "sample_lanczos(img, u, v) → vec",
          "desc": "Lanczos-3 high-quality sampling.",
          "example": "@OUT = sample_lanczos(@A, u * 0.5, v * 0.5);",
          "tags": [
            "spatial",
            "non-local"
          ],
          "aliases": []
        },
        {
          "name": "sample_mip",
          "sig": "sample_mip(img, u, v, lod) → vec",
          "desc": "Mipmap sampling with LOD. 0 = full res, 1 = half, etc. Trilinear between levels.",
          "example": "@OUT = sample_mip(@A, u, v, 2.5);",
