            "spatial",
            "sync",
            "non-local"
          ],
          "aliases": []
        },
        {
          "name": "bilateral_filter",
          "sig": "bilateral_filter(img, spatial_sigma, range_sigma) → vec",
          "desc": "Edge-preserving smoothing: blurs within regions but keeps edges. Window capped at 7×7.",
          "example": "@OUT = bilateral_filter(@A, 1.5, 0.2);",
          "tags": [
            "spatial",
            "sync",
            "non-local"
          ],
          "aliases": []
        },
        {
          "name": "sample_mip_gauss",
          "sig": "sample_mip_gauss(img, u, v, lod) → vec",
          "desc": "Gaussian-prefiltered mipmap sampling. Smoother pyramid (sigma=1.13) gives ~5 dB better exponential blur accuracy vs sample_mip.",
