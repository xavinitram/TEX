          "example": "@OUT = erode(@mask, 3);",
          "tags": [
            "sync",
            "non-local"
          ],
          "aliases": []
        },
        {
          "name": "dilate",
          "sig": "dilate(img, radius) → vec",
          "desc": "Morphological dilation (local max). Grows bright regions.",
          "example": "@OUT = dilate(@mask, 3);",
          "tags": [
            "sync",
            "non-local"
          ],
          "aliases": []
        },
        {
          "name": "sample",
          "sig": "sample(img, u, v) → vec",
          "desc": "Bilinear sample at normalized UV coordinates.",
          "example": "@OUT = sample(@A, u + 0.01, v);",
          "tags": [
            "spatial",
            "non-local"
          ],
          "aliases": []
        },
        {
          "name": "fetch",
          "sig": "fetch(img, px, py) → vec",
          "desc": "Nearest-neighbor fetch at pixel coordinates.",
