            "spatial",
            "sync",
            "non-local"
          ],
          "aliases": []
        },
        {
          "name": "gauss_blur",
          "sig": "gauss_blur(img, sigma) → vec",
          "desc": "Separable Gaussian blur. Kernel radius ≈ 3×sigma pixels. Replicate border padding.",
          "example": "@OUT = gauss_blur(@A, 2.0);",
